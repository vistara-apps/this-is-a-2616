# OpenRouter API Configuration
# Get your API key from: https://openrouter.ai/
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Search API Configuration
# Using SerpAPI as example - get your key from: https://serpapi.com/
VITE_SEARCH_API_KEY=your_search_api_key_here

# Alternative: You can use other search APIs like:
# - Bing Web Search API
# - Google Custom Search API
# - SearchAPI.io
# Just update the API endpoints in src/services/api.js accordingly